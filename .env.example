# Copy this to .env and fill in values

# ── Backend (auth; Member 1) ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI (Member 3) ────────────────────────────────────────────────────────────
# Provider selection. Choose one of:
#   anthropic  — Claude via the Anthropic API (paid; requires ANTHROPIC_API_KEY)
#   gemini     — Google Gemini via google-genai (free tier; requires GOOGLE_API_KEY)
#   ollama     — Local models via Ollama (free, offline; requires Ollama installed)
#   mock       — Deterministic fake provider, no network (used by tests)
LLM_PROVIDER=anthropic

# — Anthropic (LLM_PROVIDER=anthropic) —
# Get a key at https://console.anthropic.com/settings/keys. If unset the
# backend falls back to the mock provider and logs a warning.
ANTHROPIC_API_KEY=sk-ant-placeholder
# Optional: override the default Anthropic model.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# — Google Gemini (LLM_PROVIDER=gemini) —
# Get a key at https://aistudio.google.com/app/apikey. Free tier is generous
# for development and demos. Falls back to mock if missing.
# GOOGLE_API_KEY=your-google-api-key
# Optional: override the default Gemini model.
# GOOGLE_MODEL=gemini-2.0-flash

# — Ollama (LLM_PROVIDER=ollama) —
# No API key needed. Install from https://ollama.com, then:
#   ollama pull llama3.1
# The backend will POST to OLLAMA_URL/api/chat.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Optional: path to a JSON file that overrides any or all prompt templates
# without a code change. Keys: rewrite, summarize, grammar, custom.
# PROMPTS_OVERRIDE_PATH=./prompts.json

# WebSocket authentication fallback. Set to 0 to strictly require a JWT on
# every WS connection. 1 lets the dev user through for local demos.
ALLOW_DEV_WS_FALLBACK=1

# ── Frontend (Vite reads VITE_ prefix) ───────────────────────────────────────
VITE_API_URL=http://localhost:8080
# WebSocket lives on the same FastAPI server as the HTTP API.
VITE_WS_URL=ws://localhost:8080
