C4Component
  title Component Diagram — AI Service (Python / FastAPI)
  Container_Ext(queue, "Job Queue", "Redis / BullMQ")
  Container_Ext(llm, "LLM API")
  Container_Ext(db, "PostgreSQL")
  Container_Boundary(ai, "AI Service") {
    Component(worker, "Job Worker", "BullMQ Worker", "Polls queue, dispatches to handlers, manages retries")
    Component(registry, "Feature Handler Registry", "Python module", "Routes job type to correct handler: rewrite / summarise / translate / restructure")
    Component(prompt, "Prompt Manager", "Jinja2", "Loads templates, injects context, enforces token limits")
    Component(ctx, "Context Builder", "Python module", "Selects selected text + surrounding context up to token budget")
    Component(llmc, "LLM Client", "httpx", "Calls LLM API, handles errors and timeouts")
    Component(quota, "Quota Checker", "Python module", "Reads per-user usage; rejects over-limit jobs")
    Component(logger, "Interaction Logger", "Python module", "Writes job metadata and outcome to database")
  }
  Rel(queue, worker, "Delivers job payload")
  Rel(worker, registry, "Dispatches by type")
  Rel(registry, quota, "Check quota first")
  Rel(registry, ctx, "Build context slice")
  Rel(registry, prompt, "Assemble prompt")
  Rel(registry, llmc, "Send prompt")
  Rel(llmc, llm, "HTTPS POST")
  Rel(worker, logger, "Log outcome")
  Rel(logger, db, "Write record")
  Rel(quota, db, "Read usage")
