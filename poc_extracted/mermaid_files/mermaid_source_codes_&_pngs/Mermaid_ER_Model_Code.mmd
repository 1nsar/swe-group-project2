erDiagram
  USERS {
    uuid      id            PK
    string    email
    string    name
    uuid      org_id        FK
    timestamp created_at
  }
  ORGANISATIONS {
    uuid      id            PK
    string    name
    int       ai_quota_tokens
  }
  DOCUMENTS {
    uuid      id            PK
    string    title
    uuid      owner_id      FK
    bytea     yjs_state
    int       current_version
    bool      ai_enabled
    bool      deleted
    timestamp updated_at
  }
  DOCUMENT_VERSIONS {
    uuid      id            PK
    uuid      document_id   FK
    int       version_number
    bytea     yjs_snapshot
    uuid      saved_by      FK
    timestamp saved_at
  }
  DOCUMENT_PERMISSIONS {
    uuid      id            PK
    uuid      document_id   FK
    uuid      user_id       FK
    string    role
    timestamp granted_at
  }
  SHARE_LINKS {
    uuid      id            PK
    uuid      document_id   FK
    string    token
    string    role
    timestamp expires_at
  }
  AI_JOBS {
    uuid      id            PK
    uuid      document_id   FK
    uuid      user_id       FK
    string    feature_type
    string    status
    int       tokens_used
    string    outcome
    timestamp created_at
  }
  USER_QUOTA {
    uuid      user_id       PK
    int       tokens_used_this_month
    int       monthly_limit
    timestamp reset_at
  }
  ORGANISATIONS  ||--o{ USERS                : contains
  USERS          ||--o{ DOCUMENTS            : owns
  USERS          ||--o{ DOCUMENT_PERMISSIONS : has
  USERS          ||--o{ AI_JOBS              : submits
  USERS          ||--|| USER_QUOTA            : has
  DOCUMENTS      ||--o{ DOCUMENT_VERSIONS    : has
  DOCUMENTS      ||--o{ DOCUMENT_PERMISSIONS : has
  DOCUMENTS      ||--o{ AI_JOBS              : generates
  DOCUMENTS      ||--o{ SHARE_LINKS          : has
